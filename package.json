{
  "name": "bun-base",
  "version": "0.0.0",
  "private": true,
  "description": "Bun template baseline for adelphi-liong/diene.bun-base",
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "bun test --config=bunfig.unit.toml",
    "test:unit": "bun test --config=bunfig.unit.toml",
    "test:int": "bun test --config=bunfig.int.toml",
    "test:unit:watch": "bun test --config=bunfig.unit.toml --watch",
    "coverage:unit": "bun test --config=bunfig.unit.toml --coverage --coverage-reporter=lcov",
    "coverage:int": "bun test --config=bunfig.int.toml --coverage --coverage-reporter=lcov",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "deadcode": "knip --config knip.json",
    "deadcode:llm": "knip --config knip.llm.json --no-exit-code"
  },
  "dependencies": {
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node": "^22.10.5",
    "knip": "^5.41.1",
    "should": "^13.2.3",
    "testcontainers": "^10.16.0",
    "typescript": "^5.7.3"
  }
}
